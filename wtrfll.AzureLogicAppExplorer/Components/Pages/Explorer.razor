@page "/"
@page "/explorer"
@rendermode InteractiveServer
@inject ScanService Scan
@inject IJSRuntime JS

<PageTitle>wtrfll.AzureLogicAppExplorer – Explorer</PageTitle>

@* ── Top bar ── *@
<div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
    <h4 class="mb-0">wtrfll.AzureLogicAppExplorer</h4>

    <button class="btn btn-primary btn-sm" @onclick="RunScan" disabled="@Scan.IsScanning">
        @if (Scan.IsScanning)
        {
            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            <span>Scanning…</span>
        }
        else
        {
            <span>⟳ Scan</span>
        }
    </button>

    @if (Scan.CurrentInventory.ScannedAt > DateTimeOffset.MinValue && !Scan.IsScanning)
    {
        <small class="text-muted">
            Last scan: @Scan.CurrentInventory.ScannedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
            · @Scan.CurrentInventory.LogicApps.Count app(s)
            · @Scan.CurrentInventory.LogicApps.Sum(a => a.Workflows.Count) workflow(s)
        </small>
    }
</div>

@* ── Scan progress bar ── *@
@if (Scan.IsScanning)
{
    var pct = Scan.TotalApps > 0 ? Scan.ScannedApps * 100 / Scan.TotalApps : 0;
    <div class="mb-3">
        <div class="d-flex justify-content-between align-items-baseline mb-1">
            <small class="text-muted text-truncate me-3">
                @if (Scan.TotalApps == 0)
                {
                    <span>Discovering logic apps…</span>
                }
                else if (Scan.ScannedApps < Scan.TotalApps)
                {
                    <span>↻ @Scan.CurrentAppName</span>
                }
                else
                {
                    <span>Finalising…</span>
                }
            </small>
            <small class="text-muted text-nowrap">
                @Scan.ScannedApps / @Scan.TotalApps
            </small>
        </div>
        <div class="progress" style="height:6px;">
            <div class="progress-bar progress-bar-striped progress-bar-animated"
                 role="progressbar"
                 style="width:@pct%;"
                 aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100">
            </div>
        </div>
    </div>
}

@* ── Scan errors ── *@
@if (AllScanErrors.Any())
{
    <div class="alert alert-warning py-2 small mb-3">
        <strong>⚠ Some items could not be scanned:</strong>
        <ul class="mb-0 mt-1">
            @foreach (var err in AllScanErrors)
            {
                <li>@err</li>
            }
        </ul>
    </div>
}

@* ── Filter bar ── *@
<div class="row g-2 mb-3">

    @* Logic Apps panel *@
    <div class="col-md-4">
        <div class="border rounded p-2 bg-light h-100">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <small class="fw-semibold text-muted">Logic Apps</small>
                <span class="d-flex gap-2">
                    <a href="#" class="small" @onclick="SelectAllApps" @onclick:preventDefault>All</a>
                    <a href="#" class="small" @onclick="ClearApps" @onclick:preventDefault>Clear</a>
                </span>
            </div>
            <input class="form-control form-control-sm mb-1" placeholder="🔍 search…"
                   @bind="_appSearch" @bind:event="oninput" />
            <div style="max-height:170px; overflow-y:auto;">
                @foreach (var app in FilteredAppList)
                {
                    <div class="form-check mb-0">
                        <input class="form-check-input" type="checkbox"
                               id="app_@app" checked="@_selectedApps.Contains(app)"
                               @onchange="e => ToggleApp(app, (bool)e.Value!)" />
                        <label class="form-check-label small text-truncate d-block"
                               for="app_@app" title="@app">@app</label>
                    </div>
                }
                @if (!FilteredAppList.Any())
                {
                    <small class="text-muted fst-italic">No matches</small>
                }
            </div>
        </div>
    </div>

    @* Workflows panel *@
    <div class="col-md-4">
        <div class="border rounded p-2 bg-light h-100">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <small class="fw-semibold text-muted">Workflows</small>
                <span class="d-flex gap-2">
                    <a href="#" class="small" @onclick="SelectAllWorkflows" @onclick:preventDefault>All</a>
                    <a href="#" class="small" @onclick="ClearWorkflows" @onclick:preventDefault>Clear</a>
                </span>
            </div>
            <input class="form-control form-control-sm mb-1" placeholder="🔍 search…"
                   @bind="_wfSearch" @bind:event="oninput" />
            <div style="max-height:170px; overflow-y:auto;">
                @foreach (var (appName, workflows) in FilteredWorkflowsByApp)
                {
                    <div class="text-muted small fw-semibold mt-1 px-1"
                         style="border-bottom:1px solid #dee2e6;">@appName</div>
                    @foreach (var wf in workflows)
                    {
                        var key = WfKey(appName, wf);
                        <div class="form-check mb-0 ms-2">
                            <input class="form-check-input" type="checkbox"
                                   id="wf_@key" checked="@_selectedWorkflows.Contains(key)"
                                   @onchange="e => ToggleWorkflow(key, (bool)e.Value!)" />
                            <label class="form-check-label small text-truncate d-block"
                                   for="wf_@key" title="@wf">@wf</label>
                        </div>
                    }
                }
                @if (!FilteredWorkflowsByApp.Any())
                {
                    <small class="text-muted fst-italic ps-1">
                        @(ActiveApps.Any() ? "No matches" : "Select apps first, or leave all clear for all")
                    </small>
                }
            </div>
        </div>
    </div>

    @* Controls column *@
    <div class="col-md-4">
        <div class="border rounded p-2 bg-light h-100 d-flex flex-column gap-2">
            <div>
                <label class="form-label small fw-semibold text-muted mb-1">Keyword</label>
                <input class="form-control form-control-sm" placeholder="action, target, type…"
                       @bind="_keyword" @bind:event="oninput" />
            </div>
            <div>
                <label class="form-label small fw-semibold text-muted mb-1">View</label>
                <div class="btn-group btn-group-sm w-100" role="group">
                    <input type="radio" class="btn-check" id="modeSummary" autocomplete="off"
                           checked="@(_mode == DiagramMode.Summary)"
                           @onchange="@(() => _mode = DiagramMode.Summary)" />
                    <label class="btn btn-outline-secondary" for="modeSummary">Summary</label>
                    <input type="radio" class="btn-check" id="modeDetail" autocomplete="off"
                           checked="@(_mode == DiagramMode.Detail)"
                           @onchange="@(() => _mode = DiagramMode.Detail)" />
                    <label class="btn btn-outline-secondary" for="modeDetail">Detail</label>
                </div>
            </div>
            <div class="mt-auto d-flex flex-column gap-1">
                <button class="btn btn-primary btn-sm" @onclick="RenderDiagram"
                        disabled="@(Scan.IsScanning || Scan.CurrentInventory.LogicApps.Count == 0)">
                    ▶ Render Diagram
                </button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="ClearFilters">
                    Clear all filters
                </button>
            </div>
        </div>
    </div>
</div>

@* ── Legend ── *@
<div class="card mb-3">
    <div class="card-body p-2">
        <div class="d-flex flex-wrap align-items-center gap-3">
            <small class="fw-semibold text-muted">Legend</small>
            @foreach (var item in LegendItems)
            {
                <div class="form-check form-check-inline mb-0">
                    <input class="form-check-input" type="checkbox" id="legend_@item.ClassName"
                           checked="@(!_hiddenLegendTypes.Contains(item.ClassName))"
                           @onchange="e => ToggleLegend(item.ClassName, (bool)e.Value!)" />
                    <label class="form-check-label small d-inline-flex align-items-center gap-1" for="legend_@item.ClassName">
                        <span style="display:inline-block;width:12px;height:12px;border-radius:2px;background-color:@item.Color;"></span>
                        @item.Label
                    </label>
                </div>
            }
        </div>
    </div>
</div>

@* ── Diagram ── *@
<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center py-2">
        <span class="small fw-semibold">
            Diagram
            @if (_diagramRendered)
            {
                <span class="text-muted fw-normal ms-1">
                    — @FilteredInventory.LogicApps.Count app(s),
                    @FilteredInventory.LogicApps.Sum(a => a.Workflows.Count) workflow(s),
                    @FilteredInventory.LogicApps.Sum(a => a.Workflows.Sum(w => w.Edges.Count)) edge(s)
                </span>
            }
        </span>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-secondary" @onclick="CopyMermaid"
                    disabled="@(!_diagramRendered)">
                Copy .mmd
            </button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="DownloadMermaid"
                    disabled="@(!_diagramRendered)">
                Download .mmd
            </button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="DownloadPng"
                    disabled="@(!_diagramRendered)">
                Download PNG
            </button>
        </div>
    </div>
    <div class="card-body p-2" style="min-height:220px; overflow:auto;">
        @if (Scan.IsScanning)
        {
            <div class="text-center text-muted py-5">
                <div class="spinner-border" role="status"></div>
                <div class="mt-2">Scanning Azure…</div>
            </div>
        }
        else if (!_diagramRendered && Scan.CurrentInventory.LogicApps.Count > 0)
        {
            <div class="text-center text-muted py-5">
                Apply filters then click <strong>▶ Render Diagram</strong>.
            </div>
        }
        else if (Scan.CurrentInventory.LogicApps.Count == 0)
        {
            <div class="text-center text-muted py-5">
                No data yet — click <strong>⟳ Scan</strong> to load logic apps.
            </div>
        }
        <div id="mermaid-diagram"></div>
    </div>
</div>

@* ── Inventory table ── *@
<div class="d-flex justify-content-between align-items-start gap-2 mb-1">
    <details class="flex-grow-1 overflow-hidden">
        <summary class="small fw-semibold mb-2" style="cursor:pointer;">
            Raw Inventory
            (@FilteredInventory.LogicApps.Sum(a => a.Workflows.Sum(w => w.Edges.Count)) edges
            across @FilteredInventory.LogicApps.Sum(a => a.Workflows.Count) workflow(s))
        </summary>
        <div class="table-responsive">
            <table class="table table-sm table-hover small">
                <thead>
                    <tr>
                        <th>Logic App</th>
                        <th>Workflow</th>
                        <th>Class</th>
                        <th>Domain</th>
                        <th>Trigger</th>
                        <th>Triggered By</th>
                        <th>Interactions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var app in FilteredInventory.LogicApps)
                    {
                        @foreach (var wf in app.Workflows)
                        {
                            <tr>
                                <td class="text-muted">@(app.IsRunning ? app.Name : $"{app.Name} (stopped)")</td>
                                <td class="text-muted">@wf.Name</td>
                                <td><span class="badge @ClassificationBadgeClass(wf.Classification)">@wf.Classification</span></td>
                                <td class="text-muted">@(wf.Domain ?? "")</td>
                                <td>
                                    @if (wf.Trigger is not null)
                                    {
                                        <span class="badge @TriggerBadgeClass(wf.Trigger.Kind)">@wf.Trigger.DisplayType</span>
                                    }
                                </td>
                                <td class="text-muted">@(wf.Trigger?.Source ?? "")</td>
                                @if (wf.Edges.Count == 0)
                                {
                                    <td class="text-muted fst-italic">no outbound calls</td>
                                }
                                else
                                {
                                    <td>
                                        @foreach (var interaction in BuildInteractions(wf))
                                        {
                                            <div class="mb-1">
                                                <span class="badge @BadgeClass(interaction.CallType)">
                                                    @interaction.CallType@(interaction.Detail is not null ? $" {interaction.Detail}" : "")
                                                </span>
                                                @if (interaction.RawExpression is not null)
                                                {
                                                    <span title="Dynamic expression" class="fst-italic text-muted">@interaction.RawExpression</span>
                                                }
                                                else
                                                {
                                                    @interaction.Target
                                                }
                                                @if (interaction.Count > 1)
                                                {
                                                    <span class="text-muted">×@interaction.Count</span>
                                                }
                                            </div>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </details>
    <button class="btn btn-sm btn-outline-secondary flex-shrink-0"
            @onclick="DownloadCsv"
            disabled="@(FilteredInventory.LogicApps.Count == 0)">
        Download CSV
    </button>
</div>

@* ── Service Bus topic inventory ── *@
<div class="d-flex justify-content-between align-items-start gap-2 mb-1">
    <details class="flex-grow-1 overflow-hidden">
        <summary class="small fw-semibold mb-2" style="cursor:pointer;">
            Service Bus Topics
            (@Scan.CurrentInventory.ServiceBusTopics.Count topic(s)
            across @Scan.CurrentInventory.ServiceBusTopics.Select(t => t.Namespace).Distinct().Count() namespace(s),
            @Scan.CurrentInventory.ServiceBusTopics.Sum(t => t.Subscriptions.Count) subscription(s))
        </summary>
        <div class="table-responsive">
            <table class="table table-sm table-hover small">
                <thead>
                    <tr>
                        <th>Namespace</th>
                        <th>Topic</th>
                        <th>Subscriptions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var topic in Scan.CurrentInventory.ServiceBusTopics)
                    {
                        <tr>
                            <td class="text-muted">@topic.Namespace</td>
                            <td class="text-muted">@topic.TopicName</td>
                            @if (topic.Subscriptions.Count == 0)
                            {
                                <td class="text-muted fst-italic">no subscriptions</td>
                            }
                            else
                            {
                                <td>
                                    @foreach (var sub in topic.Subscriptions)
                                    {
                                        <span class="badge bg-secondary text-white me-1 mb-1">@sub</span>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </details>
    <button class="btn btn-sm btn-outline-secondary flex-shrink-0"
            @onclick="DownloadServiceBusCsv"
            disabled="@(Scan.CurrentInventory.ServiceBusTopics.Count == 0)">
        Download CSV
    </button>
</div>

@code {
    // ── Filter state ──────────────────────────────────────────────────────────
    private HashSet<string> _selectedApps = [];
    private HashSet<string> _selectedWorkflows = [];   // "appName||wfName" keys
    private string _appSearch = "";
    private string _wfSearch = "";
    private string _keyword = "";
    private DiagramMode _mode = DiagramMode.Detail;
    private bool _diagramRendered;
    private string _lastMermaid = "";

    private readonly MermaidBuilder _builder = new();

    // ── Legend state ─────────────────────────────────────────────────────────

    private sealed record LegendItem(string ClassName, string Label, string Color);

    private static readonly List<LegendItem> LegendItems =
    [
        new("logicapp",       "Logic App",         "#0d6efd"),
        new("workflow",       "Workflow",          "#0dcaf0"),
        new("http",           "HTTP / API",        "#6c757d"),
        new("funcapp",        "Azure Function",    "#198754"),
        new("salesforce",     "Salesforce",        "#00A1E0"),
        new("managed",        "Managed Connector", "#6f42c1"),
        new("serviceprovider","Built-in Connector","#fd7e14"),
        new("servicebus",     "Service Bus",       "#f0ad4e"),
        new("childwf",        "Child Workflow",    "#20c997"),
        new("keyvault",       "Key Vault",         "#dc3545"),
        new("trigger",        "Trigger Source",    "#6610f2"),
    ];

    // Hidden by default: Key Vault nodes are usually noise for flow diagrams
    private readonly HashSet<string> _hiddenLegendTypes = ["keyvault"];

    // ── Derived lists ─────────────────────────────────────────────────────────

    // Apps whose checkbox panels shows (filtered by search)
    private IEnumerable<string> FilteredAppList =>
        Scan.CurrentInventory.LogicApps
            .Select(a => a.Name)
            .Where(n => string.IsNullOrEmpty(_appSearch) ||
                        n.Contains(_appSearch, StringComparison.OrdinalIgnoreCase));

    // Apps whose workflows appear in the workflow panel — only explicitly selected apps.
    // Empty _selectedApps = nothing shown (use hint); FilteredInventory still shows all in the diagram.
    private IEnumerable<string> ActiveApps =>
        Scan.CurrentInventory.LogicApps.Select(a => a.Name).Where(_selectedApps.Contains);

    // Workflows grouped by app, filtered by active apps + wf search
    private IEnumerable<(string AppName, IEnumerable<string> Workflows)> FilteredWorkflowsByApp =>
        ActiveApps
            .Select(appName =>
            {
                var wfs = Scan.CurrentInventory.LogicApps
                    .FirstOrDefault(a => a.Name == appName)
                    ?.Workflows.Select(w => w.Name) ?? [];

                if (!string.IsNullOrEmpty(_wfSearch))
                    wfs = wfs.Where(n => n.Contains(_wfSearch, StringComparison.OrdinalIgnoreCase));

                return (appName, wfs);
            })
            .Where(g => g.wfs.Any());

    // The inventory narrowed to the current filter selections (drives table + diagram)
    private Inventory FilteredInventory
    {
        get
        {
            var inv = Scan.CurrentInventory;

            // App filter
            if (_selectedApps.Count > 0)
                inv = new Inventory
                {
                    LogicApps = inv.LogicApps.Where(a => _selectedApps.Contains(a.Name)).ToList(),
                    ScannedAt = inv.ScannedAt,
                };

            // Workflow filter — keys are "appName||wfName"
            if (_selectedWorkflows.Count > 0)
                inv = new Inventory
                {
                    LogicApps = inv.LogicApps.Select(a => new LogicAppInfo
                    {
                        Name = a.Name,
                        Workflows = a.Workflows
                            .Where(w => _selectedWorkflows.Contains(WfKey(a.Name, w.Name)))
                            .ToList(),
                        IsRunning = a.IsRunning,
                        ScanErrors = a.ScanErrors,
                    }).Where(a => a.Workflows.Count > 0 || !a.IsRunning).ToList(),
                    ScannedAt = inv.ScannedAt,
                };

            // Keyword filter
            if (!string.IsNullOrWhiteSpace(_keyword))
                inv = InventoryFilter.Apply(inv, keyword: _keyword);

            return inv;
        }
    }

    private IEnumerable<string> AllScanErrors =>
        Scan.CurrentInventory.ScanErrors
            .Concat(Scan.CurrentInventory.LogicApps.SelectMany(a =>
                a.ScanErrors.Select(e => $"{a.Name}: {e}")));

    // ── Scan ──────────────────────────────────────────────────────────────────

    private async Task RunScan()
    {
        _diagramRendered = false;
        _ = Scan.ScanAsync();
        while (Scan.IsScanning)
        {
            await Task.Delay(600);
            StateHasChanged();
        }
        StateHasChanged();
    }

    // ── Render ────────────────────────────────────────────────────────────────

    private async Task RenderDiagram()
    {
        var mmd = _builder.Build(FilteredInventory, _mode);
        _lastMermaid = mmd;
        _diagramRendered = true;
        StateHasChanged();
        await JS.InvokeVoidAsync("azureLogicAppExplorer.render", "mermaid-diagram", mmd);
        await ApplyLegendFilter();
    }

    // ── Legend ────────────────────────────────────────────────────────────────

    private async Task ToggleLegend(string className, bool visible)
    {
        if (visible) _hiddenLegendTypes.Remove(className);
        else _hiddenLegendTypes.Add(className);
        await ApplyLegendFilter();
    }

    private async Task ApplyLegendFilter()
        => await JS.InvokeVoidAsync("azureLogicAppExplorer.applyLegendFilter", _hiddenLegendTypes.ToList());

    // ── Selection helpers ─────────────────────────────────────────────────────

    private static string WfKey(string appName, string wfName) => $"{appName}||{wfName}";

    private void ToggleApp(string app, bool selected)
    {
        if (selected) _selectedApps.Add(app);
        else _selectedApps.Remove(app);

        // Workflow selection always starts fresh when the app set changes
        _selectedWorkflows.Clear();
    }

    private void ToggleWorkflow(string key, bool selected)
    {
        if (selected) _selectedWorkflows.Add(key);
        else _selectedWorkflows.Remove(key);
    }

    private void SelectAllApps()
    {
        foreach (var app in FilteredAppList)
            _selectedApps.Add(app);
        _selectedWorkflows.Clear();
    }

    private void ClearApps()
    {
        foreach (var app in FilteredAppList)
            _selectedApps.Remove(app);
        _selectedWorkflows.Clear();
    }

    private void SelectAllWorkflows()
    {
        foreach (var (appName, wfs) in FilteredWorkflowsByApp)
            foreach (var wf in wfs)
                _selectedWorkflows.Add(WfKey(appName, wf));
    }

    private void ClearWorkflows()
    {
        foreach (var (appName, wfs) in FilteredWorkflowsByApp)
            foreach (var wf in wfs)
                _selectedWorkflows.Remove(WfKey(appName, wf));
    }

    private void ClearFilters()
    {
        _selectedApps.Clear();
        _selectedWorkflows.Clear();
        _appSearch = "";
        _wfSearch = "";
        _keyword = "";
        _diagramRendered = false;
    }

    // ── Export ────────────────────────────────────────────────────────────────

    private async Task CopyMermaid()
        => await JS.InvokeVoidAsync("azureLogicAppExplorer.copyToClipboard", _lastMermaid);

    private async Task DownloadMermaid()
    {
        var filename = $"wtrfll.AzureLogicAppExplorer-{_mode.ToString().ToLower()}-{DateTime.Now:yyyyMMdd-HHmm}.mmd";
        await JS.InvokeVoidAsync("azureLogicAppExplorer.downloadFile", filename, _lastMermaid);
    }

    private async Task DownloadPng()
    {
        var filename = $"wtrfll.AzureLogicAppExplorer-{_mode.ToString().ToLower()}-{DateTime.Now:yyyyMMdd-HHmm}.png";
        await JS.InvokeVoidAsync("azureLogicAppExplorer.downloadDiagramPng", filename);
    }

    private async Task DownloadCsv()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Logic App,Workflow,Class,Domain,Trigger,Triggered By,Interactions");

        foreach (var app in FilteredInventory.LogicApps)
        {
            foreach (var wf in app.Workflows)
            {
                var appName        = CsvEsc(app.IsRunning ? app.Name : $"{app.Name} (stopped)");
                var wfName         = CsvEsc(wf.Name);
                var classification = wf.Classification.ToString();
                var domain         = CsvEsc(wf.Domain ?? string.Empty);
                var trigger        = CsvEsc(wf.Trigger?.DisplayType ?? string.Empty);
                var triggeredBy    = CsvEsc(wf.Trigger?.Source ?? string.Empty);

                var interactions = wf.Edges.Count == 0
                    ? string.Empty
                    : string.Join("\n", BuildInteractions(wf).Select(i =>
                    {
                        var callType = i.CallType.ToString() + (i.Detail is not null ? $" {i.Detail}" : "");
                        var target = i.RawExpression ?? i.Target;
                        var suffix = i.Count > 1 ? $" x{i.Count}" : "";
                        return $"{callType}: {target}{suffix}";
                    }));

                sb.AppendLine(string.Join(",", appName, wfName, classification, domain, trigger, triggeredBy, CsvEsc(interactions)));
            }
        }

        var filename = "inventory-" + DateTime.Now.ToString("yyyyMMdd-HHmm") + ".csv";
        await JS.InvokeVoidAsync("azureLogicAppExplorer.downloadFile", filename, sb.ToString());
    }

    private async Task DownloadServiceBusCsv()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Namespace,Topic,Subscriptions");

        foreach (var topic in Scan.CurrentInventory.ServiceBusTopics)
        {
            var ns = CsvEsc(topic.Namespace);
            var topicName = CsvEsc(topic.TopicName);
            var subscriptions = CsvEsc(string.Join("\n", topic.Subscriptions));

            sb.AppendLine(string.Join(",", ns, topicName, subscriptions));
        }

        var filename = "servicebus-topics-" + DateTime.Now.ToString("yyyyMMdd-HHmm") + ".csv";
        await JS.InvokeVoidAsync("azureLogicAppExplorer.downloadFile", filename, sb.ToString());
    }

    private static string CsvEsc(string s)
    {
        if (!s.Contains(',') && !s.Contains('"') && !s.Contains('\n') && !s.Contains('\r'))
            return s;
        // Wrap in quotes, doubling any internal quote characters
        var q = '"'.ToString();
        return q + s.Replace(q, q + q) + q;
    }

    // ── Interactions ─────────────────────────────────────────────────────────

    /// <summary>One deduplicated interaction shown as a chip in the Raw Inventory and CSV.</summary>
    private sealed record InteractionView(CallType CallType, string? Detail, string Target, string? RawExpression, int Count);

    /// <summary>
    /// Builds the deduplicated, ordered list of interactions for a workflow's edges.
    /// "Detail" is the HTTP method (Http/ApiConnection) or friendly operation
    /// (ServiceBus/KeyVault). Identical interactions (same type/detail/target) are
    /// collapsed into one entry with a Count, in first-seen order.
    /// </summary>
    private static List<InteractionView> BuildInteractions(WorkflowInfo wf) =>
        wf.Edges
            .Select(e => new InteractionView(
                e.CallType,
                e.Method ?? e.Operation,
                e.Target.Name + (e.Target.Path ?? ""),
                e.Target.RawExpression,
                1))
            .GroupBy(i => (i.CallType, i.Detail, i.Target, i.RawExpression))
            .Select(g => g.First() with { Count = g.Count() })
            .ToList();

    // ── Styling ───────────────────────────────────────────────────────────────

    private static string BadgeClass(CallType t) => t switch
    {
        CallType.Salesforce       => "bg-info text-dark",
        CallType.Http             => "bg-secondary",
        CallType.Function         => "bg-success",
        CallType.ManagedConnector => "bg-primary",
        CallType.ServiceProvider  => "bg-warning text-dark",
        CallType.ChildWorkflow    => "bg-success",
        CallType.KeyVault         => "bg-danger",
        _                         => "bg-dark",
    };

    private static string ClassificationBadgeClass(WorkflowClassification c) => c switch
    {
        WorkflowClassification.Pub    => "bg-primary",
        WorkflowClassification.Sub    => "bg-info text-dark",
        WorkflowClassification.Facade => "bg-success",
        _                              => "bg-secondary",
    };

    private static string TriggerBadgeClass(string kind) => kind switch
    {
        "ServiceBus"     => "bg-dark",
        "Http"           => "bg-secondary",
        "ApiConnection"  => "bg-primary",
        "Recurrence"     => "bg-warning text-dark",
        "ServiceProvider" => "bg-warning text-dark",
        _                => "bg-secondary",
    };
}
